rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Recipe images live under recipes/{ownerUid}/{filename}.
    match /recipes/{ownerUid}/{fileName} {
      // Anyone can view recipe images.
      allow read: if true;

      // Only the owner can upload / overwrite / delete their own images,
      // and only image files up to 5MB.
      allow write: if request.auth != null
        && request.auth.uid == ownerUid
        && (
          request.resource == null
          || (
            request.resource.size < 5 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }
  }
}
